    # =========================
    # 핸들러
    # =========================

    def open_homepage(self):
        try:
            webbrowser.open_new_tab(self.HOME_URL)
        except Exception as e:
            messagebox.showerror("오류", f"웹페이지를 열 수 없습니다.\n{e}")

    def run(self):
        c1, c2, c3, c4 = self.cards

        missing = []
        if c1.data is None and c2.data is None:
            missing.append("① 또는 ② (복무승인)")
        if c3.data is None:
            missing.append("③ 지문")
        if c4.data is None:
            missing.append("④ 설문")

        if missing:
            messagebox.showwarning(
                "필수 파일 없음",
                "다음 파일이 필요합니다:\n\n- " + "\n- ".join(missing)
            )
            return

        try:
            gov = c1.extract() if c1.data else []
            mu = c2.extract() if c2.data else []
            fp = c3.extract()
            sv = c4.extract()
        except Exception as e:
            messagebox.showerror("열 설정 오류", str(e))
            return

        try:
            unit = int(str(self.var_unit.get()).replace(",", ""))
        except Exception:
            unit = 9000
            self.var_unit.set("9000")

        def key(r): return f"{r['name']}|{r['date']}"

        # 집합
        M = set(key(r) for r in (gov + mu))   # 복무승인 (공무원 ∪ 공무직)
        F = set(key(r) for r in fp)            # 지문
        S_arr = sv                              # 설문 (원본 유지)
        S_set = set(key(r) for r in sv)

        ok, no_fp, no_duty = [], [], []
        for r in S_arr:
            k = key(r)
            in_m = k in M
            in_f = k in F
            if in_m and in_f:
                ok.append(r)
            elif not in_m:
                no_duty.append(r)
            else:
                no_fp.append(r)

        # 참고: 복무+지문은 있는데 설문 안 한 사람
        missed_meal = []
        for k in M:
            if k in F and k not in S_set:
                name, date = k.split("|", 1)
                missed_meal.append({"name": name, "date": date})
        missed_meal.sort(key=lambda x: (x["date"], x["name"]))

        total = len(ok) * unit
        total_trunc = cut_won10(total)

        # 표 렌더
        for item in self.tree.get_children():
            self.tree.delete(item)

        for r in sorted(no_duty, key=lambda x: (x["date"], x["name"])):
            k = key(r)
            self.tree.insert("", "end", tags=("bad",), values=(
                "❌ 복무승인 없음", r["name"], r["date"],
                "✗", "✓" if k in F else "✗", "✓", "결제 취소"
            ))
        for r in sorted(no_fp, key=lambda x: (x["date"], x["name"])):
            self.tree.insert("", "end", tags=("warn",), values=(
                "⚠ 지문증빙 없음", r["name"], r["date"],
                "✓", "✗", "✓", "본인 확인 필요"
            ))
        for r in sorted(ok, key=lambda x: (x["date"], x["name"])):
            self.tree.insert("", "end", tags=("ok",), values=(
                "✅ 정산가능", r["name"], r["date"],
                "✓", "✓", "✓", "-"
            ))
        for r in missed_meal:
            self.tree.insert("", "end", tags=("info",), values=(
                "📋 식사 미이용", r["name"], r["date"],
                "✓", "✓", "✗", "(참고)"
            ))

        # 범례
        self.var_legend.set(
            f"✅ 정산가능 {len(ok)}    "
            f"❌ 복무승인 없음 {len(no_duty)}    "
            f"⚠ 지문증빙 없음 {len(no_fp)}    "
            f"📋 식사 미이용 {len(missed_meal)}"
        )

        # 요약
        self.var_sum_people.set(f"{len(ok)}명")
        self.var_sum_unit.set(f"{fmt(unit)}원")
        self.var_sum_subtotal.set(f"{fmt(total)}원")
        self.var_sum_total.set(f"{fmt(total_trunc)}원")

        self.var_status.set(
            f"대조 완료 — 정산 {len(ok)} / 복무승인없음 {len(no_duty)} / "
            f"지문없음 {len(no_fp)} / 식사미이용 {len(missed_meal)}"
        )

        self._export_data = {
            "ok": ok, "no_fp": no_fp, "no_duty": no_duty,
            "missed_meal": missed_meal,
            "total": total, "total_trunc": total_trunc,
            "unit": unit, "F": F
        }

    def export_csv(self):
        d = self._export_data
        if not d:
            messagebox.showwarning("안내", "먼저 [🔍 4중 대조 실행]을 눌러 주세요.")
            return

        default = f"특근매식비_4중대조_{today_ymd()}.csv"
        path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            initialfile=default,
            filetypes=[("CSV 파일", "*.csv")]
        )
        if not path:
            return

        def key(r): return f"{r['name']}|{r['date']}"

        def esc(s):
            s = "" if s is None else str(s)
            if any(c in s for c in [",", '"', "\n", "\r"]):
                return '"' + s.replace('"', '""') + '"'
            return s

        header = ["구분", "이름", "날짜", "복무", "지문", "설문", "조치"]
        lines = [",".join(esc(h) for h in header)]

        for r in sorted(d["no_duty"], key=lambda x: (x["date"], x["name"])):
            k = key(r)
            lines.append(",".join(esc(x) for x in [
                "복무승인없음", r["name"], r["date"], "✗",
                "✓" if k in d["F"] else "✗", "✓", "결제취소"
            ]))
        for r in sorted(d["no_fp"], key=lambda x: (x["date"], x["name"])):
            lines.append(",".join(esc(x) for x in [
                "지문증빙없음", r["name"], r["date"], "✓", "✗", "✓", "본인확인"
            ]))
        for r in sorted(d["ok"], key=lambda x: (x["date"], x["name"])):
            lines.append(",".join(esc(x) for x in [
                "정산가능", r["name"], r["date"], "✓", "✓", "✓", "-"
            ]))
        for r in d["missed_meal"]:
            lines.append(",".join(esc(x) for x in [
                "식사미이용", r["name"], r["date"], "✓", "✓", "✗", "참고"
            ]))

        lines.append("")
        lines.append(f"정산인원,{len(d['ok'])}명")
        lines.append(f"1인당단가,{fmt(d['unit'])}원")
        lines.append(f"소계,{fmt(d['total'])}원")
        lines.append(f"결제액(원단위절삭),{fmt(d['total_trunc'])}원")

        try:
            with open(path, "w", encoding="utf-8-sig", newline="") as f:
                f.write("\r\n".join(lines))
            messagebox.showinfo("완료", f"CSV 저장 완료:\n{path}")
        except Exception as e:
            messagebox.showerror("저장 실패", str(e))

    def reset(self):
        for c in self.cards:
            c.clear()
        for item in self.tree.get_children():
            self.tree.delete(item)
        self.var_legend.set("대조 실행 전")
        self.var_sum_people.set("-")
        self.var_sum_unit.set("-")
        self.var_sum_subtotal.set("-")
        self.var_sum_total.set("-")
        self.var_status.set("초기화 완료")
        self._export_data = None

    def mainloop(self):
        self.root.mainloop()


