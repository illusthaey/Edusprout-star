        ).grid(row=0, column=6, padx=(10, 8), pady=5)

    def _on_drop(self, event):
        """tkinterdnd2 drop 이벤트: 경로 파싱"""
        raw = event.data
        if not raw:
            return
        # 경로에 공백 있으면 중괄호로 감싸져 들어옴: {C:/path with space/a.csv} {b.csv}
        paths = re.findall(r"\{([^}]+)\}", raw)
        if not paths:
            paths = raw.split()
        if paths:
            self.load_file(paths[0])

    def pick_file(self):
        path = filedialog.askopenfilename(
            title=f"{self.title} 파일 선택",
            filetypes=[
                ("지원 파일", "*.csv *.xlsx *.xls *.txt"),
                ("CSV 파일", "*.csv"),
                ("Excel 파일", "*.xlsx *.xls"),
                ("텍스트 파일", "*.txt"),
                ("모든 파일", "*.*")
            ]
        )
        if path:
            self.load_file(path)

    def load_file(self, path: str):
        try:
            rows = read_file_as_rows(path)
            self.data = rows
            self.filename = os.path.basename(path)
            self.status_var.set(f"✅ {self.filename} ({len(rows)}행)")
            self.badge_var.set(f"{len(rows)}행")
            self.badge_lbl.config(bg="#2A9D3F")
            self.drop.config(bg=self.BG_DROP_LOADED)
            self.frame.config(bd=2)
            if self.on_change:
                self.on_change()
        except Exception as e:
            messagebox.showerror("파일 읽기 실패", f"{os.path.basename(path)}\n\n{e}")
            self.status_var.set("❌ 읽기 실패")

    def clear(self):
        self.data = None
        self.filename = ""
        self.status_var.set("")
        self.badge_var.set("미입력")
        self.badge_lbl.config(bg="#888888")
        self.drop.config(bg=self.BG_DROP)
        self.frame.config(bd=1)

    def extract(self) -> list[dict]:
        """이 파일에서 (이름, 날짜) 튜플 리스트 추출"""
        if not self.data:
            return []

        try:
            header_row = int(self.var_header.get())
        except Exception:
            header_row = 1

        date_idx = col_to_idx(self.var_date.get())
        name_idx = col_to_idx(self.var_name.get())
        paren = bool(self.var_paren.get())

        if date_idx < 0 or name_idx < 0:
            raise RuntimeError(
                f"[{self.title}] 열 지정이 잘못되었습니다. (A~Z 알파벳 또는 1~N 숫자 입력)"
            )

        out = []
        for i in range(header_row, len(self.data)):
            r = self.data[i]
            if not r:
                continue
            name_raw = r[name_idx] if name_idx < len(r) else ""
            date_raw = r[date_idx] if date_idx < len(r) else ""
            name = norm_name(name_raw, paren)
            date = norm_date(date_raw)
            if not name or not date:
                continue
            out.append({"name": name, "date": date, "src": self.num})
        return out


