def col_to_idx(s: str) -> int:
    """알파벳 → 0-based 인덱스 (A→0, B→1, ..., Z→25, AA→26). 숫자면 1-based 취급."""
    s = str(s).strip().upper()
    if not s:
        return -1
    if s.isdigit():
        return int(s) - 1
    n = 0
    for c in s:
        code = ord(c)
        if code < 65 or code > 90:
            return -1
        n = n * 26 + (code - 64)
    return n - 1


def norm_date(s) -> str:
    """날짜 정규화: '2026-04-24 09:07:24', '2026/4/24', '4월 24일' → '2026-04-24'"""
    if s is None:
        return ""
    # datetime 객체(엑셀에서 자동 파싱된 경우)
    if isinstance(s, (datetime.datetime, datetime.date)):
        return s.strftime("%Y-%m-%d")

    s = str(s).strip()
    if not s:
        return ""

    m = re.search(r"(\d{4})[-/.](\d{1,2})[-/.](\d{1,2})", s)
    if m:
        return f"{m.group(1)}-{m.group(2).zfill(2)}-{m.group(3).zfill(2)}"

    m = re.search(r"(\d{1,2})월\s*(\d{1,2})일", s)
    if m:
        y = datetime.date.today().year
        return f"{y}-{m.group(1).zfill(2)}-{m.group(2).zfill(2)}"

    return s


def norm_name(s, remove_paren: bool) -> str:
    """이름 정규화: 괄호+괄호내용 제거(옵션), 공백 모두 제거"""
    s = str(s or "").strip()
    if remove_paren:
        s = re.sub(r"\s*\([^)]*\)\s*", "", s).strip()
    return re.sub(r"\s+", "", s)


def cut_won10(n) -> int:
    """원단위(10원) 절삭: 1111 → 1110"""
    try:
        n = int(n)
    except Exception:
        return 0
    if n <= 0:
        return 0
    return (n // 10) * 10


def fmt(n) -> str:
    try:
        return f"{int(n):,}"
    except Exception:
        return "0"


def today_ymd() -> str:
    return datetime.date.today().strftime("%Y-%m-%d")


