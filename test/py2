# 파일 읽기
# =========================

def read_file_as_rows(path: str) -> list[list]:
    """파일을 2D 리스트로 읽기. xlsx/csv/txt 지원"""
    ext = os.path.splitext(path)[1].lower()

    if ext in (".xlsx", ".xlsm"):
        if load_workbook is None:
            raise RuntimeError("openpyxl이 설치되어 있지 않습니다.\npip install openpyxl")
        wb = load_workbook(path, data_only=True)
        ws = wb.worksheets[0]
        rows = []
        for row in ws.iter_rows(values_only=True):
            rows.append(["" if v is None else v for v in row])
        return rows

    if ext == ".xls":
        raise RuntimeError("xls는 지원하지 않습니다.\nxlsx 또는 csv로 저장해 주세요.")

    # CSV / TXT: 인코딩 자동 감지
    return read_csv_auto(path)


def read_csv_auto(path: str) -> list[list]:
    """utf-8-sig → utf-8 → euc-kr → cp949 순으로 시도"""
    encodings = ("utf-8-sig", "utf-8", "euc-kr", "cp949")
    last_err = None
    for enc in encodings:
        try:
            with open(path, "r", encoding=enc, newline="") as f:
                sample = f.read(4096)
                f.seek(0)
                # 탭 vs 쉼표 자동 판별
                delim = "\t" if sample.count("\t") > sample.count(",") else ","
                reader = csv.reader(f, delimiter=delim)
                rows = []
                for row in reader:
                    if any(str(c).strip() for c in row):
                        rows.append(list(row))
                return rows
        except UnicodeDecodeError as e:
            last_err = e
            continue
        except Exception as e:
            raise e
    raise RuntimeError(f"파일 인코딩을 읽을 수 없습니다. ({last_err})")


