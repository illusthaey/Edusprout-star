    def upload_apply(self, mode: str):
        """
        mode:
          - "replace": 초기화 후 반영(교체)
          - "append": 추가 반영
        """
        path = filedialog.askopenfilename(
            title="업로드 파일 선택",
            filetypes=[
                ("Excel 파일", "*.xlsx"),
                ("CSV 파일", "*.csv"),
                ("모든 파일", "*.*"),
            ]
        )
        if not path:
            return

        try:
            rows = self._read_upload_file(path)
            self._apply_rows_from_upload(rows, mode=mode)
            messagebox.showinfo("완료", f"업로드 반영 완료: {len(rows)}명")
            self.var_status.set(f"업로드 반영 완료: {len(rows)}명")
        except Exception as e:
            messagebox.showerror("오류", f"업로드 처리 중 오류가 발생했습니다.\n\n{e}")

    def _read_upload_file(self, path: str) -> list[dict]:
        ext = os.path.splitext(path)[1].lower().strip()

        if ext == ".xls":
            raise RuntimeError("xls는 기본 지원하지 않습니다.\nxlsx 또는 csv로 저장해서 업로드해 주세요.")

        if ext == ".csv":
            return self._read_upload_csv(path)

        if ext == ".xlsx":
            return self._read_upload_xlsx(path)

        raise RuntimeError("지원하지 않는 형식입니다.\nxlsx 또는 csv 파일을 선택해 주세요.")

    def _read_upload_csv(self, path: str) -> list[dict]:
        rows_out: list[dict] = []

        with open(path, "r", encoding="utf-8-sig", newline="") as f:
            reader = csv.reader(f)
            all_rows = list(reader)

        if len(all_rows) < 2:
            return rows_out

        header = all_rows[0]
        name_idx, amt_idx, memo_idx = detect_upload_columns(header)

        for line in all_rows[1:]:
            teacher = str(line[name_idx] if name_idx < len(line) else "").strip()
            amount = to_int(line[amt_idx] if amt_idx < len(line) else 0)
            memo = "" if memo_idx is None else str(line[memo_idx] if memo_idx < len(line) else "").strip()

            if (not teacher) and amount == 0 and (not memo):
                continue

            rows_out.append({"teacher": teacher, "amount": amount, "memo": memo})

        return rows_out

    def _read_upload_xlsx(self, path: str) -> list[dict]:
        if load_workbook is None:
            raise RuntimeError("openpyxl이 설치되어 있지 않습니다.\nxlsx 업로드 기능을 사용할 수 없습니다.")

        wb = load_workbook(path, data_only=True)
        ws = wb.worksheets[0] if wb.worksheets else wb.active

        # AOA 형태로 읽기
        aoa = []
        for row in ws.iter_rows(values_only=True):
            aoa.append(list(row))

        if len(aoa) < 2:
            return []

        header = aoa[0]
        name_idx, amt_idx, memo_idx = detect_upload_columns(header)

        rows_out: list[dict] = []
        for line in aoa[1:]:
            teacher = str(line[name_idx] if name_idx < len(line) else "").strip()
            amount = to_int(line[amt_idx] if amt_idx < len(line) else 0)
            memo = "" if memo_idx is None else str(line[memo_idx] if memo_idx < len(line) else "").strip()

            if (not teacher) and amount == 0 and (not memo):
                continue

            rows_out.append({"teacher": teacher, "amount": amount, "memo": memo})

        return rows_out

    def _apply_rows_from_upload(self, rows: list[dict], mode: str = "replace"):
        """
        mode:
          - replace: 초기화 후 업로드 내용으로 반영(최소 10행 유지)
          - append: 기존 내용 유지 + 빈행 우선 채우고 부족하면 행 추가(최소 10행 유지)
        """
        if mode not in ("replace", "append"):
            mode = "replace"

        self._bulk_updating = True
        try:
            if mode == "replace":
                # 교체
                # 1) 표를 비우고
                for r in self.rows:
                    r.frame.destroy()
                self.rows.clear()

                # 2) 필요한 행 수 생성
                count = max(len(rows), MIN_ROWS_AFTER_UPLOAD)
                for _ in range(count):
                    self.add_row(recalc=False)

                # 3) 데이터 채우기
                for i, data in enumerate(rows):
                    self.rows[i].set_data(
                        teacher=data.get("teacher", ""),
                        amount=int(data.get("amount", 0) or 0),
                        memo=data.get("memo", "")
                    )

            else:
                # 추가 반영
                if len(self.rows) == 0:
                    self.init_rows(MIN_ROWS_AFTER_UPLOAD)

                for data in rows:
                    target = next((r for r in self.rows if r.is_empty()), None)
                    if target is None:
                        self.add_row(recalc=False)
                        target = self.rows[-1]
                    target.set_data(
                        teacher=data.get("teacher", ""),
                        amount=int(data.get("amount", 0) or 0),
                        memo=data.get("memo", "")
                    )

                self.ensure_min_rows(MIN_ROWS_AFTER_UPLOAD)

        finally:
            self._bulk_updating = False

        self.renumber()
        self.recalc_all()

