class CalcRow:
    """
    표 1행
    - 필요경비율(%) 칸은 기준설정 var_base_rate에 연동(읽기전용)
    - navigation을 위해 entry 참조를 유지
    """
    def __init__(self, parent, idx: int, on_change, on_delete, base_rate_var: tk.StringVar, bg="#DCEFFF"):
        self.parent = parent
        self.idx = idx
        self.on_change = on_change
        self.on_delete = on_delete

        self.frame = tk.Frame(parent, bg=bg)

        # 입력 변수
        self.var_teacher = tk.StringVar()
        self.var_amount = tk.StringVar()
        self.var_memo = tk.StringVar()

        # 필요경비율(표 칸): 기준설정과 연동(공유 var)
        self.var_rate = base_rate_var

        # 출력 라벨 값(문자열)
        self.var_expense = tk.StringVar(value="0")
        self.var_monthly = tk.StringVar(value="0")
        self.var_wcfee = tk.StringVar(value="0")
        self.var_eifee = tk.StringVar(value="0")

        # 위젯
        self.lbl_idx = tk.Label(self.frame, text=str(idx), width=4, anchor="center", bg=bg)

        self.ent_teacher = tk.Entry(self.frame, textvariable=self.var_teacher, width=16)
        self.ent_amount = tk.Entry(self.frame, textvariable=self.var_amount, width=14, justify="right")
        self.ent_rate = tk.Entry(self.frame, textvariable=self.var_rate, width=8, justify="right", state="readonly")

        self.lbl_expense = tk.Label(self.frame, textvariable=self.var_expense, width=12, anchor="e", bg=bg)
        self.lbl_monthly = tk.Label(self.frame, textvariable=self.var_monthly, width=12, anchor="e", bg=bg)
        self.lbl_wcfee = tk.Label(self.frame, textvariable=self.var_wcfee, width=12, anchor="e", bg=bg)
        self.lbl_eifee = tk.Label(self.frame, textvariable=self.var_eifee, width=12, anchor="e", bg=bg)

        self.ent_memo = tk.Entry(self.frame, textvariable=self.var_memo, width=22)
        self.btn_del = tk.Button(self.frame, text="삭제", width=6, command=self._delete_click)

        # 배치
        self.lbl_idx.grid(row=0, column=0, padx=2, pady=1, sticky="nsew")
        self.ent_teacher.grid(row=0, column=1, padx=2, pady=1, sticky="nsew")
        self.ent_amount.grid(row=0, column=2, padx=2, pady=1, sticky="nsew")
        self.ent_rate.grid(row=0, column=3, padx=2, pady=1, sticky="nsew")

        self.lbl_expense.grid(row=0, column=4, padx=2, pady=1, sticky="nsew")
        self.lbl_monthly.grid(row=0, column=5, padx=2, pady=1, sticky="nsew")
        self.lbl_wcfee.grid(row=0, column=6, padx=2, pady=1, sticky="nsew")
        self.lbl_eifee.grid(row=0, column=7, padx=2, pady=1, sticky="nsew")

        self.ent_memo.grid(row=0, column=8, padx=2, pady=1, sticky="nsew")
        self.btn_del.grid(row=0, column=9, padx=2, pady=1, sticky="nsew")

        # 이벤트: 입력 변경시 재계산
        for v in (self.var_teacher, self.var_amount, self.var_memo):
            v.trace_add("write", lambda *_: self.on_change())

        # 금액 포맷팅(포커스 아웃에서 정리)
        self.ent_amount.bind("<FocusOut>", self._format_amount_on_blur)
        self.ent_amount.bind("<Return>", self._format_amount_on_blur)

    def _format_amount_on_blur(self, _evt=None):
        raw = self.var_amount.get()
        n = to_int(raw)
        self.var_amount.set(fmt(n) if n > 0 else "")
        self.on_change()

    def _delete_click(self):
        self.on_delete(self)

    def set_index(self, idx: int):
        self.idx = idx
        self.lbl_idx.config(text=str(idx))

    def get_amount(self) -> int:
        return to_int(self.var_amount.get())

    def get_teacher(self) -> str:
        return self.var_teacher.get().strip()

    def get_memo(self) -> str:
        return self.var_memo.get().strip()

    def is_empty(self) -> bool:
        return (not self.get_teacher()) and (self.get_amount() == 0) and (not self.get_memo())

    def set_data(self, teacher: str = "", amount: int = 0, memo: str = ""):
        self.var_teacher.set(teacher or "")
        self.var_amount.set(fmt(amount) if int(amount or 0) > 0 else "")
        self.var_memo.set(memo or "")

    def set_outputs(self, expense: int, monthly: int, wcfee: int, eifee: int):
        self.var_expense.set(fmt(expense))
        self.var_monthly.set(fmt(monthly))
        self.var_wcfee.set(fmt(wcfee))
        self.var_eifee.set(fmt(eifee))

    def entry_by_col(self, col: int) -> tk.Entry:
        # 0: teacher, 1: amount, 2: rate(readonly), 3: memo
        if col == 0:
            return self.ent_teacher
        if col == 1:
            return self.ent_amount
        if col == 2:
            return self.ent_rate
        return self.ent_memo


