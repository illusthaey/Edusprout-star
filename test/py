        tk.Entry(box, textvariable=var, width=width, justify="right").pack(anchor="w")

    def _apply_base_rate_edit_state(self):
        allow = bool(self.var_edit_base_rate.get())
        self.ent_base_rate.config(state="normal" if allow else "disabled")
        if allow:
            # 체크 시 바로 입력 가능하게
            self.after(50, lambda: (self.ent_base_rate.focus_set(), self.ent_base_rate.selection_range(0, tk.END)))

    def _on_frame_configure(self, _evt=None):
        self.canvas.configure(scrollregion=self.canvas.bbox("all"))

    def _on_canvas_configure(self, _evt=None):
        canvas_width = self.canvas.winfo_width()
        self.canvas.itemconfig(self.canvas_window, width=canvas_width)

    # =========================
    # 행/표 관리
    # =========================

    def init_rows(self, n: int):
        for r in self.rows:
            r.frame.destroy()
        self.rows.clear()

        for _ in range(n):
            self.add_row(recalc=False)

        self.renumber()
        self.recalc_all()
        self.var_status.set("초기화 완료")

    def ensure_min_rows(self, min_rows: int):
        while len(self.rows) < min_rows:
            self.add_row(recalc=False)

    def add_row(self, recalc: bool = True):
        idx = len(self.rows) + 1
        row = CalcRow(
            self.rows_frame,
            idx=idx,
            on_change=self.recalc_all,
            on_delete=self.delete_row,
            base_rate_var=self.var_base_rate,
            bg=self.BG
        )
        row.frame.pack(fill="x", pady=1)
        self.rows.append(row)

        # ✅ 엑셀 같은 이동 바인딩(방향키/Enter)
        self._bind_nav(row)

        if recalc:
            self.renumber()
            self.recalc_all()

    def delete_row(self, row: CalcRow):
        if row in self.rows:
            row.frame.destroy()
            self.rows.remove(row)
            self.renumber()
            self.recalc_all()

    def renumber(self):
        for i, r in enumerate(self.rows, start=1):
            r.set_index(i)

    # =========================
    # ✅ 키보드 이동(엑셀 느낌)
    # =========================

    def _focus_select(self, ent: tk.Entry):
        try:
            ent.focus_set()
            ent.selection_range(0, tk.END)
            ent.icursor(tk.END)
        except Exception:
            pass

    def _caret_at_start(self, ent: tk.Entry) -> bool:
        try:
            return int(ent.index(tk.INSERT)) == 0
        except Exception:
            return True

    def _caret_at_end(self, ent: tk.Entry) -> bool:
        try:
            return int(ent.index(tk.INSERT)) == len(ent.get())
        except Exception:
            return True

    def _move_to(self, row_idx: int, col_idx: int):
        if row_idx < 0 or col_idx < 0:
            return
        if row_idx >= len(self.rows):
            return
        target = self.rows[row_idx].entry_by_col(col_idx)
        self._focus_select(target)

    def _on_enter(self, _evt, row_obj: CalcRow, col_idx: int, down: bool):
        try:
            row_idx = self.rows.index(row_obj)
        except ValueError:
            return "break"

        next_row = row_idx + (1 if down else -1)

        # 마지막 행에서 Enter(아래)면 자동 행 추가
        if down and next_row >= len(self.rows):
            self.add_row(recalc=True)
            next_row = len(self.rows) - 1

        if 0 <= next_row < len(self.rows):
            self._move_to(next_row, col_idx)

        return "break"

    def _on_up_down(self, _evt, row_obj: CalcRow, col_idx: int, delta_row: int):
        try:
            row_idx = self.rows.index(row_obj)
        except ValueError:
            return "break"
        next_row = row_idx + delta_row
        if 0 <= next_row < len(self.rows):
            self._move_to(next_row, col_idx)
        return "break"

    def _on_left(self, evt, row_obj: CalcRow, col_idx: int):
        ent = evt.widget
        if isinstance(ent, tk.Entry) and not self._caret_at_start(ent):
            return  # 기본 동작
        if col_idx - 1 >= 0:
            try:
                row_idx = self.rows.index(row_obj)
                self._move_to(row_idx, col_idx - 1)
                return "break"
            except ValueError:
                return "break"
        return

    def _on_right(self, evt, row_obj: CalcRow, col_idx: int):
        ent = evt.widget
        if isinstance(ent, tk.Entry) and not self._caret_at_end(ent):
            return  # 기본 동작
        if col_idx + 1 <= 3:
            try:
                row_idx = self.rows.index(row_obj)
                self._move_to(row_idx, col_idx + 1)
                return "break"
            except ValueError:
                return "break"
        return

    def _bind_nav(self, row: CalcRow):
        entries = [row.ent_teacher, row.ent_amount, row.ent_rate, row.ent_memo]

        for col_idx, ent in enumerate(entries):
            # Enter / Shift+Enter
            ent.bind("<Return>", lambda e, r=row, c=col_idx: self._on_enter(e, r, c, down=True))
            ent.bind("<Shift-Return>", lambda e, r=row, c=col_idx: self._on_enter(e, r, c, down=False))

            # Up/Down
            ent.bind("<Up>", lambda e, r=row, c=col_idx: self._on_up_down(e, r, c, -1))
            ent.bind("<Down>", lambda e, r=row, c=col_idx: self._on_up_down(e, r, c, +1))

            # Left/Right (커서가 끝/처음일 때만 이동)
            ent.bind("<Left>", lambda e, r=row, c=col_idx: self._on_left(e, r, c))
            ent.bind("<Right>", lambda e, r=row, c=col_idx: self._on_right(e, r, c))

    # =========================
    # 계산
    # =========================

    def _get_base_params(self):
        base_rate = clamp_rate(self.var_base_rate.get())  # %
        wc_rate = clamp_rate(self.var_wc_rate.get()) / 100.0  # % -> ratio
        floor = cut_won10(self.var_floor.get())
        return base_rate, wc_rate, floor

    def recalc_all(self):
        if self._bulk_updating:
            return

        base_rate, wc_rate, floor = self._get_base_params()

        sum_amount = 0
        sum_expense = 0
        sum_monthly = 0
        sum_wc = 0
        sum_ei = 0

        for r in self.rows:
            amount = r.get_amount()
            rate = base_rate  # ✅ 표의 필요경비율은 기준설정값 고정(연동)

            expense = cut_won10(amount * (rate / 100.0))
            monthly = cut_won10(max(amount - expense, 0))

            wc_fee = cut_won10(int(monthly * wc_rate))

            ei_base = floor if (monthly >= 800000 and monthly < floor) else monthly
            ei_fee = cut_won10(int(ei_base * EI_PERSONAL_RATE))

            r.set_outputs(expense, monthly, wc_fee, ei_fee)

            sum_amount += amount
            sum_expense += expense
            sum_monthly += monthly
            sum_wc += wc_fee
            sum_ei += ei_fee

        self.lbl_sum_amount.config(text=fmt(cut_won10(sum_amount)))
        self.lbl_sum_expense.config(text=fmt(cut_won10(sum_expense)))
        self.lbl_sum_monthly.config(text=fmt(cut_won10(sum_monthly)))
        self.lbl_sum_wc.config(text=fmt(cut_won10(sum_wc)))
        self.lbl_sum_ei.config(text=fmt(cut_won10(sum_ei)))

        self.var_status.set("계산 완료")

    def reset_all(self):
        self.var_edit_base_rate.set(False)
        self.var_base_rate.set("14.9")
        self.var_wc_rate.set("0.33")
        self.var_floor.set("1330000")
        self._apply_base_rate_edit_state()
        self.init_rows(10)

    # =========================
    # Export / Copy
    # =========================

    def _collect_rows(self):
        base_rate, _, _ = self._get_base_params()
        out = []
        for r in self.rows:
            teacher = r.get_teacher()
            amount = r.get_amount()
            memo = r.get_memo()
            if (not teacher) and amount == 0 and (not memo):
                continue

            out.append({
                "idx": r.idx,
                "teacher": teacher,
                "amount": amount,
                "rate": base_rate,
                "expense": to_int(r.var_expense.get()),
                "monthly": to_int(r.var_monthly.get()),
                "wc": to_int(r.var_wcfee.get()),
                "ei": to_int(r.var_eifee.get()),
                "memo": memo
            })
        return out

    def copy_table(self):
        header = ["순번","강사명","강사료 지급액","필요경비율(%)","필요경비","월보수액","산재보험료(개인)","고용보험료(개인, 예상값)","비고"]
        lines = ["\t".join(header)]
        for x in self._collect_rows():
            lines.append("\t".join([
                str(x["idx"]),
                x["teacher"],
                str(x["amount"]),
                str(x["rate"]),
                str(x["expense"]),
                str(x["monthly"]),
                str(x["wc"]),
                str(x["ei"]),
                x["memo"]
            ]))
        text = "\n".join(lines)

        self.clipboard_clear()
        self.clipboard_append(text)
        self.update()
        messagebox.showinfo("완료", "복사 완료(엑셀에 붙여넣기 가능).")

    def save_csv(self):
        rows = self._collect_rows()
        if not rows:
            messagebox.showwarning("안내", "저장할 데이터가 없습니다.")
            return

        default = f"방과후강사_월보수액_{today_ymd()}.csv"
        path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            initialfile=default,
            filetypes=[("CSV 파일", "*.csv")]
        )
        if not path:
            return

        header = ["순번","강사명","강사료 지급액","필요경비율(%)","필요경비","월보수액","산재보험료(개인)","고용보험료(개인, 예상값)","비고"]

        def csv_escape(s):
            s = "" if s is None else str(s)
            if any(c in s for c in [",", '"', "\n", "\r"]):
                return '"' + s.replace('"', '""') + '"'
            return s

        lines = [",".join(csv_escape(h) for h in header)]
        for x in rows:
            lines.append(",".join([
                csv_escape(x["idx"]),
                csv_escape(x["teacher"]),
                csv_escape(x["amount"]),
                csv_escape(x["rate"]),
                csv_escape(x["expense"]),
                csv_escape(x["monthly"]),
                csv_escape(x["wc"]),
                csv_escape(x["ei"]),
                csv_escape(x["memo"]),
            ]))

        with open(path, "w", encoding="utf-8-sig", newline="") as f:
            f.write("\r\n".join(lines))

        messagebox.showinfo("완료", f"CSV 저장 완료:\n{path}")

