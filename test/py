def to_int(val) -> int:
    if val is None:
        return 0
    s = str(val)
    s = re.sub(r"[^\d\-\.]", "", s)
    try:
        n = float(s) if s else 0.0
    except Exception:
        return 0
    if n != n:  # NaN
        return 0
    return int(n)


def cut_won10(n) -> int:
    n = int(to_int(n))
    if n <= 0:
        return 0
    return (n // 10) * 10


def fmt(n: int) -> str:
    try:
        return f"{int(n):,}"
    except Exception:
        return "0"


def clamp_rate(r) -> float:
    try:
        x = float(r)
    except Exception:
        return 0.0
    if x < 0:
        return 0.0
    if x > 100:
        return 100.0
    return x


def today_ymd() -> str:
    d = datetime.date.today()
    return d.strftime("%Y-%m-%d")


def normalize_header_cell(v) -> str:
    return str(v or "").replace(" ", "").replace("\t", "").replace("\n", "").lower()


def detect_upload_columns(header_row: list) -> tuple[int, int, int | None]:
    headers = [normalize_header_cell(x) for x in (header_row or [])]

    # name 후보: 강사명, 이름
    name_idx = next((i for i, h in enumerate(headers) if ("강사명" in h) or ("이름" in h)), -1)

    # amount 후보: 강사료, 품의금액, 지급액, 금액(단 필요경비/보험 제외)
    def is_amount_header(h: str) -> bool:
        return (
            ("강사료" in h)
            or ("품의금액" in h)
            or ("지급액" in h)
            or (("금액" in h) and ("필요경비" not in h) and ("보험" not in h))
        )

    amt_idx = next((i for i, h in enumerate(headers) if is_amount_header(h)), -1)

    # memo 후보: 비고, 메모, memo
    memo_idx = next((i for i, h in enumerate(headers) if ("비고" in h) or ("메모" in h) or ("memo" in h)), -1)
    if memo_idx == -1:
        memo_idx = None

    # 못 찾으면 기본: A=이름, B=금액
    if name_idx == -1:
        name_idx = 0
    if amt_idx == -1:
        amt_idx = 1

    # 혹시 같은 열로 잡히면 B(1)로 보정
    if amt_idx == name_idx:
        amt_idx = 1 if name_idx != 1 else 0

    return name_idx, amt_idx, memo_idx


